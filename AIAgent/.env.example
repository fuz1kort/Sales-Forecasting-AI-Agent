# Sales Forecasting Agent - Environment Configuration
# Скопируйте этот файл в .env и заполните необходимые значения

# === API KEYS ===
# Выберите один из провайдеров LLM

# YandexGPT API Key (рекомендуется для русскоязычных пользователей)
YANDEX_API_KEY=your_yandex_api_key_here

# OpenAI API Key (альтернатива)
# OPENAI_API_KEY=your_openai_api_key_here

# === REDIS CONFIGURATION ===
# Для хранения сессий (опционально, по умолчанию используется in-memory хранилище)
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=0

# === APPLICATION SETTINGS ===
# Провайдер LLM: yandex или openai
LLM_PROVIDER=yandex

# Название API
API_TITLE=Sales Forecasting Agent API

# Версия API
API_VERSION=4.0

# === OPTIONAL SETTINGS ===
# Максимальный размер датасета для обработки (в МБ)
MAX_DATASET_SIZE_MB=100

# Таймаут для API запросов (в секундах)
API_TIMEOUT_SECONDS=30

# Уровень логирования: DEBUG, INFO, WARNING, ERROR
LOG_LEVEL=INFO</content>
